{
  "name": "hono-pino",
  "version": "0.10.3",
  "description": "A pino logger plugin for hono",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maou-shonen/hono-pino.git"
  },
  "license": "MIT",
  "author": "maou-shonen",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./debug-log": {
      "import": {
        "types": "./dist/debug-log/index.d.ts",
        "default": "./dist/debug-log/index.js"
      },
      "require": {
        "types": "./dist/debug-log/index.d.cts",
        "default": "./dist/debug-log/index.cjs"
      }
    }
  },
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "hono",
    "pino",
    "logger"
  ],
  "homepage": "https://github.com/maou-shonen/hono-pino#readme",
  "bugs": {
    "url": "https://github.com/maou-shonen/hono-pino/issues"
  },
  "packageManager": "pnpm@10.12.4",
  "pnpm": {
    "overrides": {
      "picomatch": "^4.0.4",
      "yaml": "^2.8.3"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsup --watch",
    "build": "tsup-node",
    "ci": "biome ci",
    "format": "biome format --write",
    "typecheck": "tsc",
    "lint": "biome lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "pino": ">=7.1.0"
  },
  "dependencies": {
    "defu": "^6.1.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/node": "^20.19.9",
    "@vitest/coverage-v8": "^4.1.2",
    "hono": "^4.12.10",
    "husky": "^9.1.7",
    "jsr": "^0.14.0",
    "pino": "^10.3.1",
    "pino-abstract-transport": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
